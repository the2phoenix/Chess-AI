# Copy this file to .env and fill in real values. NEVER commit .env.

# ---------- Supabase (auth + database) ----------
# Frontend-safe (with Row Level Security enabled):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side ONLY (offline trainer / backend). Never expose to the browser:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Engine backend (optional, for live play) ----------
# Public URL the frontend calls for live server-side moves (e.g. Render):
NEXT_PUBLIC_ENGINE_API_URL=https://your-backend.onrender.com

# ---------- Reminder ----------
# Secrets live in env vars only, never in the repo. The browser only ever gets
# the anon/publishable key; the service-role key stays server-side.
